# Copy to .env. push_airtable.py loads this file automatically.

AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=

# Optional: AIRTABLE_SYNC_MEDIA=1  (+ media.csv) for Media table sync.
# Ignore patterns (applied by export_cues_csv.py to fileset/media-derived lists):
# AIRTABLE_IGNORE_REGEX=^090-                 # one regex for both filesets + media names
# AIRTABLE_IGNORE_FILESETS_REGEX=^090-        # fileset keys only
# AIRTABLE_IGNORE_MEDIA_REGEX=^090-           # media filenames only

# Table/field overrides (defaults match docs/AIRTABLE.md):
# AIRTABLE_CHANNELS_TABLE=Channels
# AIRTABLE_FILESETS_TABLE=Filesets
# AIRTABLE_FILESETS_WRITABLE_FIELDS=Channels,Used in show,Channel versions
# AIRTABLE_CUES_TABLE=Cues
# AIRTABLE_CUE_VIDEO_LAYERS_FIELD=Video layers used
# AIRTABLE_CUE_WRITABLE_FIELDS=Track,CUE_NAME,Filesets,Video layers used
# AIRTABLE_CUE_NOTES_FIELD=Notes
# See push_airtable.py for the rest if you rename fields in Airtable.
