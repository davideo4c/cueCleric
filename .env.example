# Copy to .env and fill in. push_airtable.py loads .env automatically (no extra packages).

AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=

# Media table is OFF by default (no media.csv). Opt in:
# AIRTABLE_SYNC_MEDIA=1

# Optional (defaults shown; Media_* only when AIRTABLE_SYNC_MEDIA=1):
# AIRTABLE_MEDIA_TABLE=Media
# AIRTABLE_MEDIA_NAME_FIELD=Name
# AIRTABLE_MEDIA_VERSION_FIELD=Version
# AIRTABLE_MEDIA_USED_FIELD=Used in show
# AIRTABLE_MEDIA_ON_DISK_FIELD=On disk
# AIRTABLE_MEDIA_WRITABLE_FIELDS=Version,Used in show,On disk
# AIRTABLE_CHANNELS_TABLE=Channels
# AIRTABLE_CHANNELS_NAME_FIELD=Name
# AIRTABLE_FILESETS_TABLE=Filesets
# AIRTABLE_FILESETS_NAME_FIELD=Name
# AIRTABLE_FILESETS_CHANNELS_FIELD=Channels
# AIRTABLE_FILESETS_MEDIA_FIELD=Media
# AIRTABLE_FILESETS_CHANNEL_VERSIONS_FIELD=Channel versions
# AIRTABLE_FILESETS_USED_FIELD=Used in show
# AIRTABLE_FILESETS_WRITABLE_FIELDS=Channels,Used in show,Channel versions
# (Add Media only if you need to clear Filesets→Media links; [] can 422 on some bases.)
# AIRTABLE_CUES_TABLE=Cues
# AIRTABLE_CUE_MEDIA_FIELD=Media
# AIRTABLE_CUE_FILESETS_FIELD=Filesets
# AIRTABLE_CUE_PRIMARY_FIELD=CUE_NUMBER
# AIRTABLE_CUE_WRITABLE_FIELDS=Track,CUE_NAME,Filesets
# Add ,Media only if your Cues table has a Media link field (requires AIRTABLE_SYNC_MEDIA + media.csv to fill).
# AIRTABLE_CUE_NOTES_FIELD=Notes
